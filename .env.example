# Copy this file to .env and fill in real values, or export these directly.
# Zero-key mode: set MOCK_MODE=true and ignore everything else below.

MOCK_MODE=false

# --- LLM provider ---
LLM_PROVIDER=anthropic          # anthropic | gemini | mock
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_API_KEY=AIza-...
GEMINI_MODEL=gemini-1.5-flash

# --- Web search provider ---
WEB_SEARCH_PROVIDER=tavily      # tavily | mock
TAVILY_API_KEY=tvly-...

# --- Paper search provider ---
PAPER_SEARCH_PROVIDER=arxiv     # arxiv | mock   (arxiv needs no key, it's a public API)

# --- Optional: LangSmith tracing (spec section 9) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=multi-perspective-research-assistant
